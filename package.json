{
  "name": "@ecosy/styled",
  "version": "1.1.0",
  "description": "A zero-dependency, cross-platform styling engine for React Web and React Native.",
  "keywords": [
    "react",
    "react-native",
    "styled",
    "styling",
    "css-in-js",
    "theme",
    "ecosy"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "react-native": "./src/react/index.ts",
      "types": "./dist/react/index.d.ts",
      "source": "./src/react/index.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./react/styled": {
      "react-native": "./src/react/styled.ts",
      "types": "./dist/react/styled.d.ts",
      "source": "./src/react/styled.ts",
      "import": "./dist/react/styled.mjs",
      "require": "./dist/react/styled.js"
    },
    "./react-native": {
      "react-native": "./src/react-native/index.ts",
      "types": "./dist/react-native/index.d.ts",
      "source": "./src/react-native/index.ts",
      "import": "./dist/react-native/index.mjs",
      "require": "./dist/react-native/index.js"
    },
    "./react-native/styled": {
      "react-native": "./src/react-native/styled.ts",
      "types": "./dist/react-native/styled.d.ts",
      "source": "./src/react-native/styled.ts",
      "import": "./dist/react-native/styled.mjs",
      "require": "./dist/react-native/styled.js"
    },
    "./slice": {
      "react-native": "./src/slice/index.ts",
      "types": "./dist/slice/index.d.ts",
      "source": "./src/slice/index.ts",
      "import": "./dist/slice/index.mjs",
      "require": "./dist/slice/index.js"
    },
    "./theme/*": {
      "react-native": "./src/theme/*.ts",
      "types": "./dist/theme/*.d.ts",
      "source": "./src/theme/*.ts",
      "import": "./dist/theme/*.mjs",
      "require": "./dist/theme/*.js"
    },
    "./types/*": {
      "react-native": "./src/types/*.ts",
      "types": "./dist/types/*.d.ts",
      "source": "./src/types/*.ts",
      "import": "./dist/types/*.mjs",
      "require": "./dist/types/*.js"
    }
  },
  "files": [
    "dist",
    "agents",
    "CHANGELOG.md"
  ],
  "repository": "git+ssh://git@github.com/material-atomic/ecosy-styled.git",
  "author": "Material Atomic <material@ecosy.io>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "agents": {
    "prompts": {
      "styled": "$this://agents/PROMPT.md"
    },
    "skills": {
      "$overview": "$this://agents/skills/index.md",
      "styled-react-web": "$this://agents/skills/styled-react-web/SKILL.md",
      "styled-react-native": "$this://agents/skills/styled-react-native/SKILL.md"
    },
    "workflows": [
      "prompts.styled",
      "skills.styled-react-web",
      "skills.styled-react-native"
    ],
    "examples": {
      "project": {
        "repository": "github.com:material-atomic/ecosy-styled/main/examples/styled-demo",
        "url": "https://styled-demo.ecosy.io"
      }
    }
  },
  "peerDependencies": {
    "@ecosy/core": "^0.3.4",
    "@ecosy/react": "^0.3.1",
    "@ecosy/store": "^0.2.1",
    "react": "^19.2.6",
    "react-native": "^0.85.3"
  },
  "devDependencies": {
    "@ecosy/core": "^0.3.4",
    "@ecosy/react": "^0.3.1",
    "@ecosy/store": "^0.2.1",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^13.0.6",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-native": "^0.85.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "eslint src/ && rollup -c",
    "prepublishOnly": "yarn clean && yarn build",
    "dev": "rollup -c --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  }
}
